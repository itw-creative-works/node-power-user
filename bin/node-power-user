#!/usr/bin/env node
const { hideBin } = require('yargs/helpers');
const rawArgs = hideBin(process.argv);

// help(false)/version(false): yargs must not intercept --help/--version —
// commands like `npu npx <cmd> --help` need those flags to reach the child.
// boolean('force'): without it, `npu --force npx ...` parses as --force=npx
// and swallows the command token.
const argv = require('yargs')(rawArgs).help(false).version(false).boolean('force').parseSync();

// Commands that pass args through to a child (npx) re-parse from raw argv
argv.raw = rawArgs;

// --cwd / -C: run as if invoked from a different directory
const targetDir = argv.cwd || argv.C;
if (targetDir) {
  process.chdir(targetDir);
}

const cli = new (require('../dist/cli.js'))();
(async function() {
  'use strict';

  // cli.process logs errors itself — exit non-zero without an unhandled
  // rejection crash (which dumps noise from libraries with global handlers)
  try {
    await cli.process(argv);
  } catch (e) {
    process.exitCode = 1;
  }
}());
